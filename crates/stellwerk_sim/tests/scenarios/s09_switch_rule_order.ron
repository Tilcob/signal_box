#![enable(unwrap_newtypes, implicit_some)]
// Szenario 9 (Plan §5): Regelreihenfolge — die erste passende Regel gewinnt.
// t0 (Klasse 1, Ziel OST) matcht BEIDE Regeln: Die Zielregel steht zuerst
// und schickt ihn korrekt nach OST. Bei vertauschter Reihenfolge würde die
// Klassenregel ihn nach NORD fehlleiten — dieses Szenario würde rot.
// t1 (Klasse 1, Ziel NORD) fällt durch Regel 1 und matcht Regel 2.
(
    level: (
        name: "S09 — Regelreihenfolge",
        buildable: [(x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 2, y: 1)],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [(id: 0, cell: (x: 0, y: 0), dir: W)],
        sinks: [
            (id: 0, cell: (x: 2, y: 0), dir: E, label: "OST"),
            (id: 1, cell: (x: 2, y: 1), dir: NE, label: "NORD"),
        ],
        schedule: [
            (train: 0, class: 1, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 100),
            (train: 1, class: 1, length: 800, speed: 100, source: 0, sink: 1, depart: 6, due: 150),
        ],
        par: (throughput: 80, material: 7, lateness: 0),
    ),
    layout: (
        pieces: [
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 2, y: 0), a: W, b: E),
            (cell: (x: 2, y: 1), a: SW, b: NE),
        ],
        switches: [
            (cell: (x: 1, y: 0), stem: W, branches: (E, NE), default_branch: 0, rules: [
                (when: DestIs(0), branch: 0),
                (when: ClassIs(1), branch: 1),
            ]),
        ],
        signals: [],
    ),
    expect: Success(last_arrival_by: 80),
)
