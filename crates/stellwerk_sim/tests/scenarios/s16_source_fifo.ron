#![enable(unwrap_newtypes, implicit_some)]
// Szenario 16 (Plan §5): Einfahrts-FIFO. Drei Züge mit 2 Ticks Abstand im
// Fahrplan — die Quelle ist aber erst frei, wenn der Vordermann die
// Einfahrkante geräumt hat (Kopf ≥ 1300). Tatsächliche Abfahrten ~1/14/27,
// Ankünfte ~60/73/86 in Fahrplan-Reihenfolge; Verspätung läuft währenddessen
// weiter (GDD §7.5).
(
    level: (
        name: "S16 — Einfahrts-FIFO",
        buildable: [(x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 3, y: 0), (x: 4, y: 0), (x: 5, y: 0)],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [(id: 0, cell: (x: 0, y: 0), dir: W)],
        sinks: [(id: 0, cell: (x: 5, y: 0), dir: E, label: "OST")],
        schedule: [
            (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 60),
            (train: 1, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 2, due: 70),
            (train: 2, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 4, due: 80),
        ],
        par: (throughput: 90, material: 6, lateness: 10),
    ),
    layout: (
        pieces: [
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 1, y: 0), a: W, b: E),
            (cell: (x: 2, y: 0), a: W, b: E),
            (cell: (x: 3, y: 0), a: W, b: E),
            (cell: (x: 4, y: 0), a: W, b: E),
            (cell: (x: 5, y: 0), a: W, b: E),
        ],
        switches: [],
        signals: [],
    ),
    expect: Success(last_arrival_by: 100, last_arrival_at_least: 80),
)
