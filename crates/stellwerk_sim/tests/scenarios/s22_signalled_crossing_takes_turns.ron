#![enable(unwrap_newtypes, implicit_some)]
// Szenario 22: dieselbe Kreuzung wie s21, aber mit BLOCKSIGNALEN an beiden
// Zufahrten. Ohne Signal kollidieren die zwei Züge am Kreuzungspunkt (s21);
// mit Blocksignal greift das Punkt-Interlocking: einer reserviert den Punkt
// und fährt, der andere wartet kurz und fährt danach. Beide kommen an —
// kein Deadlock (die Routen sind getrennte Blöcke, nur der Punkt ist geteilt).
//
//              (0,1) NORD↑
//                │
//  (-1,0)──sig──(0,0)──────(1,0)  Zeile 0 (t0 ostwärts → OST)
//                │sig
//              (0,-1) ↑t1
(
    level: (
        name: "S22 — Kreuzung mit Blocksignal: abwechselnd",
        buildable: [
            (x: -1, y: 0), (x: 0, y: 0), (x: 1, y: 0),
            (x: 0, y: -1), (x: 0, y: 1),
        ],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [
            (id: 0, cell: (x: -1, y: 0), dir: W),
            (id: 1, cell: (x: 0, y: -1), dir: S),
        ],
        sinks: [
            (id: 0, cell: (x: 1, y: 0), dir: E, label: "OST"),
            (id: 1, cell: (x: 0, y: 1), dir: N, label: "NORD"),
        ],
        schedule: [
            (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 200),
            (train: 1, class: 0, length: 800, speed: 100, source: 1, sink: 1, depart: 0, due: 200),
        ],
        par: (throughput: 100, material: 10, lateness: 0),
    ),
    layout: (
        pieces: [
            (cell: (x: -1, y: 0), a: W, b: E),
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 0, y: 0), a: N, b: S),
            (cell: (x: 1, y: 0), a: W, b: E),
            (cell: (x: 0, y: -1), a: N, b: S),
            (cell: (x: 0, y: 1), a: N, b: S),
        ],
        switches: [],
        signals: [
            (cell: (x: -1, y: 0), at: E, kind: Block),
            (cell: (x: 0, y: -1), at: N, kind: Block),
        ],
    ),
    expect: Success(last_arrival_by: 120, last_arrival_at_least: 40),
)
