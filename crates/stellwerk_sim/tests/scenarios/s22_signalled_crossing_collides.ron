#![enable(unwrap_newtypes, implicit_some)]
// Szenario 22: dieselbe Kreuzung wie s21, mit BLOCKSIGNALEN an beiden
// Zufahrten — beide Züge treffen GLEICHZEITIG am Kreuzungspunkt ein. Ein
// Blocksignal sichert nur seinen Block; es reserviert den Kreuzungspunkt
// NICHT voraus, garantiert also keine Durchfahrt. Beide fahren auf den Punkt
// → Kollision. Ein Kettensignal reserviert die Fahrstraße voraus und
// verhindert das (s14). Bei GESTAFFELTER Ankunft nähmen Blocksignale den
// Punkt dagegen weiter abwechselnd (s13).
//
//              (0,1) NORD↑
//                │
//  (-1,0)──sig──(0,0)──────(1,0)  Zeile 0 (t0 ostwärts → OST)
//                │sig
//              (0,-1) ↑t1
(
    level: (
        name: "S22 — Kreuzung mit Blocksignal: Kollision",
        buildable: [
            (x: -1, y: 0), (x: 0, y: 0), (x: 1, y: 0),
            (x: 0, y: -1), (x: 0, y: 1),
        ],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [
            (id: 0, cell: (x: -1, y: 0), dir: W),
            (id: 1, cell: (x: 0, y: -1), dir: S),
        ],
        sinks: [
            (id: 0, cell: (x: 1, y: 0), dir: E, label: "OST"),
            (id: 1, cell: (x: 0, y: 1), dir: N, label: "NORD"),
        ],
        schedule: [
            (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 200),
            (train: 1, class: 0, length: 800, speed: 100, source: 1, sink: 1, depart: 0, due: 200),
        ],
        par: (throughput: 100, material: 10, lateness: 0),
    ),
    layout: (
        pieces: [
            (cell: (x: -1, y: 0), a: W, b: E),
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 0, y: 0), a: N, b: S),
            (cell: (x: 1, y: 0), a: W, b: E),
            (cell: (x: 0, y: -1), a: N, b: S),
            (cell: (x: 0, y: 1), a: N, b: S),
        ],
        switches: [],
        signals: [
            (cell: (x: -1, y: 0), at: E, kind: Block),
            (cell: (x: 0, y: -1), at: N, kind: Block),
        ],
    ),
    expect: Collision(trains: (0, 1)),
)
