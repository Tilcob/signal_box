#![enable(unwrap_newtypes, implicit_some)]
// Szenario 17 (Plan §5): Ein langer Zug (1800 LE) überspannt zwei Blöcke
// gleichzeitig. Der Folgezug wird am Quellsignal gehalten, solange der
// lange Zug IRGENDEINEN Teil im Mittelblock (Zellen 1–3) hat — auch wenn
// sein Kopf längst im dritten Block fährt (Kopf 4000–5800).
(
    level: (
        name: "S17 — Langer Zug über zwei Blöcke",
        buildable: [(x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 3, y: 0), (x: 4, y: 0), (x: 5, y: 0)],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [(id: 0, cell: (x: 0, y: 0), dir: W)],
        sinks: [(id: 0, cell: (x: 5, y: 0), dir: E, label: "OST")],
        schedule: [
            (train: 0, class: 0, length: 1800, speed: 100, source: 0, sink: 0, depart: 0, due: 100),
            (train: 1, class: 0, length: 800, speed: 150, source: 0, sink: 0, depart: 2, due: 120),
        ],
        par: (throughput: 90, material: 10, lateness: 0),
    ),
    layout: (
        pieces: [
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 1, y: 0), a: W, b: E),
            (cell: (x: 2, y: 0), a: W, b: E),
            (cell: (x: 3, y: 0), a: W, b: E),
            (cell: (x: 4, y: 0), a: W, b: E),
            (cell: (x: 5, y: 0), a: W, b: E),
        ],
        switches: [],
        signals: [
            (cell: (x: 0, y: 0), at: E, kind: Block),
            (cell: (x: 3, y: 0), at: E, kind: Block),
        ],
    ),
    expect: Success(last_arrival_by: 100, last_arrival_at_least: 70),
)
