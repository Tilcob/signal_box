#![enable(unwrap_newtypes, implicit_some)]
// Szenario 13: Doppelkreuzung NUR mit Blocksignalen. Seit dem Diamant-Umbau
// sind die zwei Routen getrennte Blöcke, die sich nur an den Kreuzungspunkten
// X1=(1,0)/X2=(3,0) sperren — die Züge nehmen den Punkt abwechselnd, kein
// Deadlock mehr (früher verschmolz die Kreuzung alles zu einem Block).
// t0 fährt W→O über Zeile 0; t1 von Süden durch X2, über Zeile 1 nach Westen
// und durch X1 nach SUED. Beide kommen an.
//
//        (1,1)──(2,1)──(3,1)        Zeile 1 (t1 westwärts)
//          │b2            │
//  (0,0)──(X1)──(2,0)──(X2)──(4,0)  Zeile 0 (t0 ostwärts)
//    a1    │      a2      │b1
//        (1,-1)        (3,-1)
//        SUED↓          ↑t1
(
    level: (
        name: "S13 — Deadlock an der Doppelkreuzung",
        buildable: [
            (x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 3, y: 0), (x: 4, y: 0),
            (x: 1, y: 1), (x: 2, y: 1), (x: 3, y: 1),
            (x: 1, y: -1), (x: 3, y: -1),
        ],
        fixed: (pieces: [], switches: [], signals: []),
        sources: [
            (id: 0, cell: (x: 0, y: 0), dir: W),
            (id: 1, cell: (x: 3, y: -1), dir: S),
        ],
        sinks: [
            (id: 0, cell: (x: 4, y: 0), dir: E, label: "OST"),
            (id: 1, cell: (x: 1, y: -1), dir: S, label: "SUED"),
        ],
        schedule: [
            (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 200),
            (train: 1, class: 0, length: 800, speed: 100, source: 1, sink: 1, depart: 0, due: 200),
        ],
        par: (throughput: 100, material: 20, lateness: 0),
    ),
    layout: (
        pieces: [
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 1, y: 0), a: W, b: E),
            (cell: (x: 1, y: 0), a: N, b: S),
            (cell: (x: 2, y: 0), a: W, b: E),
            (cell: (x: 3, y: 0), a: W, b: E),
            (cell: (x: 3, y: 0), a: N, b: S),
            (cell: (x: 4, y: 0), a: W, b: E),
            (cell: (x: 1, y: -1), a: N, b: S),
            (cell: (x: 3, y: -1), a: N, b: S),
            (cell: (x: 1, y: 1), a: E, b: S),
            (cell: (x: 2, y: 1), a: W, b: E),
            (cell: (x: 3, y: 1), a: S, b: W),
        ],
        switches: [],
        signals: [
            (cell: (x: 0, y: 0), at: E, kind: Block),
            (cell: (x: 2, y: 0), at: E, kind: Block),
            (cell: (x: 3, y: -1), at: N, kind: Block),
            (cell: (x: 1, y: 1), at: S, kind: Block),
        ],
    ),
    expect: Success(last_arrival_by: 90),
)
