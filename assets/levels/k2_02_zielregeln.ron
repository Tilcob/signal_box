#![enable(unwrap_newtypes, implicit_some)]
// Kapitel 2, Level 2 — Lehre: Die Weiche ist das Programm. Vier Züge,
// abwechselnd nach OST und NORD — eine Zielregel an der Weiche genügt.
(
    name: "2.2 Zielregeln",
    buildable: [
        (x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 3, y: 0), (x: 4, y: 0),
        (x: 1, y: 1), (x: 2, y: 1), (x: 3, y: 1),
        (x: 1, y: 2), (x: 2, y: 2), (x: 3, y: 2),
    ],
    fixed: (
        pieces: [
            (cell: (x: 0, y: 0), a: W, b: E),
            (cell: (x: 4, y: 0), a: W, b: E),
            (cell: (x: 3, y: 2), a: N, b: S),
        ],
        switches: [],
        signals: [],
    ),
    sources: [(id: 0, cell: (x: 0, y: 0), dir: W)],
    sinks: [
        (id: 0, cell: (x: 4, y: 0), dir: E, label: "OST"),
        (id: 1, cell: (x: 3, y: 2), dir: N, label: "NORD"),
    ],
    schedule: [
        (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 60),
        (train: 1, class: 0, length: 800, speed: 100, source: 0, sink: 1, depart: 8, due: 80),
        (train: 2, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 16, due: 90),
        (train: 3, class: 0, length: 800, speed: 100, source: 0, sink: 1, depart: 24, due: 110),
    ],
    par: (throughput: 100, material: 7, lateness: 0),
)
