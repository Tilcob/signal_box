#![enable(unwrap_newtypes, implicit_some)]
// Kapitel 2, Level 1 — Lehre: Gegenverkehr braucht eine Ausweiche: zwei
// Weichen, ein Schleifengleis und vier Blocksignale, damit sich die Züge
// mitten im Netz begegnen können.
(
    name: "2.1 Die Ausweiche",
    buildable: [
        (x: 0, y: 0), (x: 1, y: 0), (x: 2, y: 0), (x: 3, y: 0), (x: 4, y: 0),
        (x: 1, y: 1), (x: 2, y: 1), (x: 3, y: 1),
    ],
    fixed: (
        pieces: [(cell: (x: 0, y: 0), a: W, b: E), (cell: (x: 4, y: 0), a: W, b: E)],
        switches: [],
        signals: [],
    ),
    sources: [
        (id: 0, cell: (x: 0, y: 0), dir: W),
        (id: 1, cell: (x: 4, y: 0), dir: E),
    ],
    sinks: [
        (id: 0, cell: (x: 4, y: 0), dir: E, label: "OST"),
        (id: 1, cell: (x: 0, y: 0), dir: W, label: "WEST"),
    ],
    schedule: [
        (train: 0, class: 0, length: 800, speed: 100, source: 0, sink: 0, depart: 0, due: 60),
        (train: 1, class: 0, length: 800, speed: 100, source: 1, sink: 1, depart: 0, due: 70),
    ],
    par: (throughput: 62, material: 18, lateness: 0),
)
